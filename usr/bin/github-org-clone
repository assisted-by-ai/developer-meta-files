#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Clone (or fast-forward) every public, non-archived, non-fork repo of
## a GitHub user/organization into <dest-dir>/<repo-name>/. Idempotent.
## Run `github-org-clone --help` for full usage.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

# shellcheck source=../libexec/developer-meta-files/github-org-lib.bsh
source /usr/libexec/developer-meta-files/github-org-lib.bsh

## Sanity-check the system 'wc' binary before using it. wc can core
## dump on some systems (rspamd issue #5137); helper-scripts provides
## a one-liner test that prints a clear diagnostic and exits non-zero
## if wc is broken, so we never silently produce an empty count.
##
## ${HELPER_SCRIPTS_PATH:-} prefix lets a caller (e.g. derivative-maker
## running with helper-scripts as a submodule) point at an in-tree
## checkout instead of the system install. Empty default = system
## install at /usr/libexec/helper-scripts/.
# shellcheck source=/dev/null
source "${HELPER_SCRIPTS_PATH:-}"/usr/libexec/helper-scripts/wc-test.sh

include_private=0
include_archived=0
include_forks=0
include_re=''
exclude_re=''
shallow=0
url_scheme='ssh'
jobs=4
dry_run=0
verbose=0

show_help() {
  cat <<'EOF'
Clone or update every selected repo of a GitHub user/organization
into a local directory tree. Idempotent - re-running fetches and
fast-forwards each existing clone, never merging or rebasing.

Usage:
  github-org-clone [OPTIONS] <source-org> [<dest-dir>]

Layout:
  <dest-dir>/<repo-name>/      ## one git checkout per repo, flat

Options:
  --include-private    include private repos (default: skip)
  --include-archived   include archived repos (default: skip)
  --include-forks      include fork repos     (default: skip)
  --include REGEX      only repos whose name matches REGEX
  --exclude REGEX      drop repos whose name matches REGEX
  --shallow            clone with --depth=1 (no update support)
  --ssh                use git@github.com:... URLs (default)
  --https              use https://github.com/... URLs
  --jobs N             parallel clones/fetches (default: 4)
  --dry-run            report planned actions, do nothing
  -v, --verbose        print each git command
  -h, --help           show this help and exit

Auth (optional for public reads):
  ${GITHUB_TOKEN} env var, or chmod-600 ~/.config/github-token. Without
  a token, requests go out unauthenticated and are subject to GitHub's
  60-req/hr-per-IP rate limit.
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --include-private)
      include_private=1
      shift
      ;;
    --include-archived)
      include_archived=1
      shift
      ;;
    --include-forks)
      include_forks=1
      shift
      ;;
    --include)
      [ "$#" -ge 2 ] || { printf '%s\n' "missing value for --include" >&2; exit 64; }
      include_re="$2"
      shift 2
      ;;
    --exclude)
      [ "$#" -ge 2 ] || { printf '%s\n' "missing value for --exclude" >&2; exit 64; }
      exclude_re="$2"
      shift 2
      ;;
    --shallow)
      shallow=1
      shift
      ;;
    --ssh)
      url_scheme='ssh'
      shift
      ;;
    --https)
      url_scheme='https'
      shift
      ;;
    --jobs)
      [ "$#" -ge 2 ] || { printf '%s\n' "missing value for --jobs" >&2; exit 64; }
      jobs="$2"
      shift 2
      ;;
    --dry-run)
      dry_run=1
      shift
      ;;
    -v|--verbose)
      verbose=1
      shift
      ;;
    -h|--help)
      show_help
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      printf '%s\n' "unknown option: '$1'" >&2
      exit 64
      ;;
    *)
      break
      ;;
  esac
done

if [ "$#" -lt 1 ] || [ "$#" -gt 2 ]; then
  show_help >&2
  exit 64
fi

source_org="$1"
dest_dir="${2:-.}"

ghorg_require_deps
ghorg_validate_name "${source_org}" user
if ! [[ "${jobs}" =~ ^[1-9][0-9]*$ ]]; then
  printf '%s\n' "invalid --jobs value: '${jobs}' (expected positive integer)" >&2
  exit 64
fi
if [ "${jobs}" -gt 64 ]; then
  printf '%s\n' "invalid --jobs value: '${jobs}' (max 64)" >&2
  exit 64
fi

repo_url() {
  local repo

  repo="$1"

  case "${url_scheme}" in
    ssh)   printf '%s' "git@github.com:${source_org}/${repo}.git" ;;
    https) printf '%s' "https://github.com/${source_org}/${repo}.git" ;;
  esac
}

## Clone a missing repo or fast-forward an existing one. Each call is
## standalone so it can be safely backgrounded for parallelism.
clone_or_update_one() {
  local repo repo_dir url existing_url current_branch
  local safe_existing_url safe_branch
  local -a clone_args

  repo="$1"

  ghorg_validate_name "${repo}" repo || return 0

  repo_dir="${dest_dir}/${repo}"
  url="$(repo_url "${repo}")"

  if [ -d "${repo_dir}/.git" ]; then
    ## Origin-URL collision check: if an existing clone's origin
    ## points elsewhere (because the operator reused dest_dir across
    ## source orgs and a name collided), skip rather than silently
    ## fetch from the wrong upstream.
    existing_url="$(git -C "${repo_dir}" remote get-url origin 2>/dev/null || true)"
    if [ -n "${existing_url}" ] && [ "${existing_url}" != "${url}" ]; then
      safe_existing_url="$(ghorg_safe_print "${GHORG_MAX_DISPLAY_LEN}" "${existing_url}")"
      printf '%s\n' \
        "warn: '${repo_dir}': origin is '${safe_existing_url}', expected '${url}'; skipping (name collision?)" >&2
      return 0
    fi

    if [ "${dry_run}" = '1' ]; then
      printf '%s\n' "DRY-RUN: update ${repo_dir}"
      return 0
    fi
    [ "${verbose}" = '1' ] && printf '%s\n' "update: ${repo_dir}"
    ## --ff-only refuses anything but a clean fast-forward; safer than
    ## `pull` for unattended runs where divergence would otherwise
    ## attempt a merge.
    git -C "${repo_dir}" fetch --prune --tags -- origin
    current_branch="$(git -C "${repo_dir}" symbolic-ref --short HEAD 2>/dev/null || true)"
    if [ -n "${current_branch}" ]; then
      ## @{u} is an unambiguous symbolic ref for the upstream of the
      ## current branch - immune to tag/branch name collisions.
      if ! git -C "${repo_dir}" merge --ff-only "@{u}" 2>/dev/null; then
        safe_branch="$(ghorg_safe_print "${GHORG_MAX_REPO_NAME_LEN}" "${current_branch}")"
        printf '%s\n' \
          "warn: '${repo_dir}': '${safe_branch}' not fast-forwardable, skipping merge" >&2
      fi
    fi
  elif [ -e "${repo_dir}" ]; then
    printf '%s\n' "warn: '${repo_dir}' exists and is not a git checkout, skipping" >&2
    return 0
  else
    if [ "${dry_run}" = '1' ]; then
      printf '%s\n' "DRY-RUN: clone ${url} -> ${repo_dir}"
      return 0
    fi
    [ "${verbose}" = '1' ] && printf '%s\n' "clone: ${url}"
    clone_args=( clone )
    [ "${shallow}" = '1' ] && clone_args+=( --depth=1 )
    ## protocol.file.allow=never / protocol.ext.allow=never block a
    ## hostile upstream from redirecting a sub-fetch through file:// or
    ## ext:: helper protocols (CVE-class).
    clone_args+=(
      --config protocol.file.allow=never
      --config protocol.ext.allow=never
    )
    clone_args+=( -- "${url}" "${repo_dir}" )
    ## GIT_LFS_SKIP_SMUDGE=1 prevents the LFS smudge filter from
    ## auto-fetching arbitrary objects on clone if the upstream's
    ## .gitattributes points binary files at LFS. Operators who
    ## genuinely want LFS payloads can pre-export the env var to
    ## something other than 1.
    GIT_LFS_SKIP_SMUDGE="${GIT_LFS_SKIP_SMUDGE:-1}" git "${clone_args[@]}"
  fi
}

main() {
  local repos repo_count active repo

  mkdir -p -- "${dest_dir}"

  repos="$(ghorg_list_repos "${source_org}" \
    "${include_private}" "${include_archived}" "${include_forks}" \
    | ghorg_filter_names "${include_re}" "${exclude_re}" \
    | sort --unique)"

  if [ -z "${repos}" ]; then
    printf '%s\n' 'no repos matched.' >&2
    return 0
  fi

  repo_count="$(printf '%s\n' "${repos}" | wc --lines)"
  printf '%s\n' "${repo_count} repos to process under ${dest_dir}"

  ## Bounded parallelism: keep at most ${jobs} background jobs alive.
  active=0
  while IFS= read -r repo; do
    [ -z "${repo}" ] && continue
    clone_or_update_one "${repo}" &
    active=$(( active + 1 ))
    if [ "${active}" -ge "${jobs}" ]; then
      wait -n || true
      active=$(( active - 1 ))
    fi
  done <<< "${repos}"
  wait
}

main
