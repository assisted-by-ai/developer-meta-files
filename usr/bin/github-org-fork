#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Fork every selected repository from a source GitHub user/org into a
## target user/org. Idempotent. Optional flags re-apply per-repo
## settings on the target side. Run `github-org-fork --help` for full
## usage.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

# shellcheck source=../libexec/developer-meta-files/github-org-lib.bsh
source /usr/libexec/developer-meta-files/github-org-lib.bsh

include_private=0
include_archived=0
include_forks=0
include_re=''
exclude_re=''
disable_issues=0
disable_wiki=0
disable_projects=0
actions_state='leave'    ## enable | disable | leave
workflow_perms='leave'   ## read | write | leave
dry_run=0
verbose=0

show_help() {
  cat <<'EOF'
Fork every selected repo from a source GitHub user/org into a target
user/org. Idempotent: existing forks are left in place; only missing
ones are created. Optional flags also (re-)apply per-repo settings on
the target side, so the script doubles as a drift corrector on every
run.

Usage:
  github-org-fork [OPTIONS] <source-owner> <target-owner>

Options:
  --include-private    include private repos       (default: skip)
  --include-archived   include archived repos      (default: skip)
  --include-forks      include forks of other repos (default: skip)
  --include REGEX      only repos whose name matches REGEX
  --exclude REGEX      drop repos whose name matches REGEX
  --disable-issues     turn off issues on each target repo
  --disable-wiki       turn off wiki on each target repo
  --disable-projects   turn off projects on each target repo
  --actions {enable|disable|leave}
                       set Actions state on each target repo
                       (default: leave settings unchanged)
  --workflow-perms {read|write|leave}
                       set default GITHUB_TOKEN permissions in target
                       workflows (default: leave)
  --dry-run            report planned actions, do nothing
  -v, --verbose        print each API call's effect
  -h, --help           show this help and exit

Auth:
  ${GITHUB_TOKEN} env var, or chmod-600 ~/.config/github-token. Token
  needs `repo` scope; for --actions or --workflow-perms it also needs
  `workflow`.
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --include-private)
      include_private=1
      shift
      ;;
    --include-archived)
      include_archived=1
      shift
      ;;
    --include-forks)
      include_forks=1
      shift
      ;;
    --include)
      [ "$#" -ge 2 ] || { printf '%s\n' "missing value for --include" >&2; exit 64; }
      include_re="$2"
      shift 2
      ;;
    --exclude)
      [ "$#" -ge 2 ] || { printf '%s\n' "missing value for --exclude" >&2; exit 64; }
      exclude_re="$2"
      shift 2
      ;;
    --disable-issues)
      disable_issues=1
      shift
      ;;
    --disable-wiki)
      disable_wiki=1
      shift
      ;;
    --disable-projects)
      disable_projects=1
      shift
      ;;
    --actions)
      [ "$#" -ge 2 ] || { printf '%s\n' "missing value for --actions" >&2; exit 64; }
      case "$2" in
        enable|disable|leave)
          actions_state="$2"
          ;;
        *)
          printf '%s\n' "invalid --actions value: '$2'" >&2
          exit 64
          ;;
      esac
      shift 2
      ;;
    --workflow-perms)
      [ "$#" -ge 2 ] || { printf '%s\n' "missing value for --workflow-perms" >&2; exit 64; }
      case "$2" in
        read|write|leave)
          workflow_perms="$2"
          ;;
        *)
          printf '%s\n' "invalid --workflow-perms value: '$2'" >&2
          exit 64
          ;;
      esac
      shift 2
      ;;
    --dry-run)
      dry_run=1
      shift
      ;;
    -v|--verbose)
      verbose=1
      shift
      ;;
    -h|--help)
      show_help
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      printf '%s\n' "unknown option: '$1'" >&2
      exit 64
      ;;
    *)
      break
      ;;
  esac
done

if [ "$#" -ne 2 ]; then
  show_help >&2
  exit 64
fi

source_owner="$1"
target_owner="$2"

ghorg_require_deps
ghorg_validate_name "${source_owner}" user
ghorg_validate_name "${target_owner}" user

## POST /repos/{owner}/{repo}/forks. The `organization` body field
## applies only when the target is an Organization; for a User it must
## be omitted, and GitHub then forks to the *authenticated* user
## regardless of `target_owner`. Because there is no API parameter to
## name a different user, we explicitly verify the auth user equals
## target_owner up front and refuse otherwise - the alternative is
## creating forks in the wrong account while logs claim otherwise.
fork_one() {
  local repo target_type body auth_user result status
  local safe_target safe_auth

  repo="$1"

  ghorg_validate_name "${repo}" repo || return 1

  target_type="$(ghorg_account_type "${target_owner}")" || return 1

  if [ "${target_type}" = 'Organization' ]; then
    body="$(jq -n --arg org "${target_owner}" -- \
      '{organization: $org, default_branch_only: false}')"
  else
    auth_user="$(ghorg_authenticated_user)" || return 1
    if [ "${auth_user}" != "${target_owner}" ]; then
      safe_target="$(ghorg_safe_print "${GHORG_MAX_USER_LOGIN_LEN}" "${target_owner}")"
      safe_auth="$(ghorg_safe_print "${GHORG_MAX_USER_LOGIN_LEN}" "${auth_user}")"
      printf '%s\n' \
        "error: target user '${safe_target}' does not match auth user '${safe_auth}'; refusing to fork" >&2
      return 1
    fi
    body="$(jq -n -- '{default_branch_only: false}')"
  fi
  if [ "${dry_run}" = '1' ]; then
    printf '%s\n' "DRY-RUN: fork ${source_owner}/${repo} -> ${target_owner}/${repo}"
    return 0
  fi
  result="$(ghorg_api POST "/repos/${source_owner}/${repo}/forks" "${body}")"
  status="$(ghorg_status_of "${result}")"
  case "${status}" in
    202|201)
      printf '%s\n' "forked: ${source_owner}/${repo} -> ${target_owner}/${repo}"
      ;;
    *)
      printf '%s\n' "error: fork '${source_owner}/${repo}': HTTP '${status}'" >&2
      return 1
      ;;
  esac
}

## Detects cross-source name collisions. When a target repo with the
## given name already exists, look up its parent.full_name; if the
## parent isn't the source we're processing, the operator has two
## different upstream repos collapsed onto one mirror name. We warn
## but don't fail - the operator sees the collision and decides what
## to do (rename, archive, or accept).
check_collision() {
  local repo parent expected safe_repo safe_parent safe_expected

  repo="$1"

  parent="$(ghorg_repo_parent "${target_owner}" "${repo}")" || return 0
  expected="${source_owner}/${repo}"

  if [ -n "${parent}" ] && [ "${parent}" != "${expected}" ]; then
    safe_repo="$(ghorg_safe_print "${GHORG_MAX_REPO_NAME_LEN}" "${repo}")"
    safe_parent="$(ghorg_safe_print "${GHORG_MAX_DISPLAY_LEN}" "${parent}")"
    safe_expected="$(ghorg_safe_print "${GHORG_MAX_DISPLAY_LEN}" "${expected}")"
    printf '%s\n' \
      "warn: collision: '${target_owner}/${safe_repo}' exists as fork of '${safe_parent}', expected '${safe_expected}'" >&2
  fi
}

## Apply the optional --disable-* / --actions / --workflow-perms flags
## to a single target repo. Idempotent and skipped entirely when no
## flags were passed.
configure_one() {
  local repo patch enabled body result status

  repo="$1"

  ## Repo settings PATCH only sent if at least one toggle was requested.
  if [ "${disable_issues}${disable_wiki}${disable_projects}" != '000' ]; then
    patch='{}'
    [ "${disable_issues}"   = '1' ] && patch="$(printf '%s' "${patch}" | jq -- '. + {has_issues: false}')"
    [ "${disable_wiki}"     = '1' ] && patch="$(printf '%s' "${patch}" | jq -- '. + {has_wiki: false}')"
    [ "${disable_projects}" = '1' ] && patch="$(printf '%s' "${patch}" | jq -- '. + {has_projects: false}')"
    if [ "${dry_run}" = '1' ]; then
      printf '%s\n' "DRY-RUN: PATCH ${target_owner}/${repo} ${patch}"
    else
      result="$(ghorg_api PATCH "/repos/${target_owner}/${repo}" "${patch}")"
      status="$(ghorg_status_of "${result}")"
      [ "${status}" != '200' ] && \
        printf '%s\n' "warn: PATCH '${target_owner}/${repo}': HTTP '${status}'" >&2
      [ "${verbose}" = '1' ] && [ "${status}" = '200' ] && \
        printf '%s\n' "configured: ${target_owner}/${repo} ${patch}"
    fi
  fi

  if [ "${actions_state}" != 'leave' ]; then
    [ "${actions_state}" = 'enable' ] && enabled='true' || enabled='false'
    body="$(jq -n --argjson e "${enabled}" -- '{enabled: $e, allowed_actions: "all"}')"
    if [ "${dry_run}" = '1' ]; then
      printf '%s\n' "DRY-RUN: actions ${actions_state} on ${target_owner}/${repo}"
    else
      result="$(ghorg_api PUT "/repos/${target_owner}/${repo}/actions/permissions" "${body}")"
      status="$(ghorg_status_of "${result}")"
      case "${status}" in
        204|200) [ "${verbose}" = '1' ] && \
          printf '%s\n' "actions=${actions_state} on ${target_owner}/${repo}" ;;
        *) printf '%s\n' \
          "warn: actions ${actions_state} on ${target_owner}/${repo}: HTTP ${status}" >&2 ;;
      esac
    fi
  fi

  if [ "${workflow_perms}" != 'leave' ]; then
    body="$(jq -n --arg p "${workflow_perms}" -- \
      '{default_workflow_permissions: $p, can_approve_pull_request_reviews: false}')"
    if [ "${dry_run}" = '1' ]; then
      printf '%s\n' "DRY-RUN: workflow-perms ${workflow_perms} on ${target_owner}/${repo}"
    else
      result="$(ghorg_api PUT \
        "/repos/${target_owner}/${repo}/actions/permissions/workflow" "${body}")"
      status="$(ghorg_status_of "${result}")"
      case "${status}" in
        204|200) [ "${verbose}" = '1' ] && \
          printf '%s\n' "workflow-perms=${workflow_perms} on ${target_owner}/${repo}" ;;
        *) printf '%s\n' \
          "warn: workflow-perms ${workflow_perms} on ${target_owner}/${repo}: HTTP ${status}" >&2 ;;
      esac
    fi
  fi
}

## Populates the associative array named in $1 with one key per
## newline-separated repo name in $2. Empty lines skipped.
fork_main_build_repo_set() {
  local set_name list_text repo_name

  set_name="$1"
  list_text="$2"

  while IFS= read -r repo_name; do
    [ -z "${repo_name}" ] && continue
    printf -v "${set_name}[${repo_name}]" '%s' '1'
  done <<< "${list_text}"
}

main() {
  local target_type auth_user source_repos target_repos repo_name
  local -A target_set=()
  local -a missing=() to_configure=()

  printf '%s\n' "source: ${source_owner} -> target: ${target_owner}"

  ## If the target is a User, GitHub will fork to the authenticated
  ## user regardless of target_owner. Verify equivalence up front and
  ## abort the whole run rather than discovering this per repo.
  target_type="$(ghorg_account_type "${target_owner}")"
  if [ "${target_type}" = 'User' ]; then
    auth_user="$(ghorg_authenticated_user)"
    if [ "${auth_user}" != "${target_owner}" ]; then
      printf '%s\n' \
        "error: target user '${target_owner}' does not match auth user '${auth_user}'; aborting" >&2
      exit 1
    fi
  fi

  source_repos="$(ghorg_list_repos "${source_owner}" \
    "${include_private}" "${include_archived}" "${include_forks}" \
    | ghorg_filter_names "${include_re}" "${exclude_re}" \
    | sort --unique)"
  ## Target side: do NOT exclude forks - target forks ARE the mirrors.
  target_repos="$(ghorg_list_repos "${target_owner}" 1 1 1 \
    | sort --unique)"

  if [ -z "${source_repos}" ]; then
    printf '%s\n' 'no source repos matched.' >&2
    return 0
  fi

  ## Set difference: source repos absent from target.
  ## ${target_set[$key]:-} is required because nounset triggers on an
  ## associative-array subscript with an unset key.
  fork_main_build_repo_set target_set "${target_repos}"
  while IFS= read -r repo_name; do
    [ -z "${repo_name}" ] && continue
    [ -z "${target_set[${repo_name}]:-}" ] && missing+=( "${repo_name}" )
  done <<< "${source_repos}"

  if [ "${#missing[@]}" -eq 0 ]; then
    printf '%s\n' 'no new forks needed.'
  else
    for repo_name in "${missing[@]}"; do
      fork_one "${repo_name}"
    done
  fi

  ## Re-list target after potential new forks (GitHub fork creation is
  ## async; brand-new forks may not appear yet, but configure_one is
  ## idempotent on the next run).
  target_repos="$(ghorg_list_repos "${target_owner}" 1 1 1 \
    | sort --unique)"

  ## Set intersection: source repos that exist on target. Configures
  ## only matching repos; leaves unrelated target-side repos alone.
  target_set=()
  fork_main_build_repo_set target_set "${target_repos}"
  while IFS= read -r repo_name; do
    [ -z "${repo_name}" ] && continue
    [ -n "${target_set[${repo_name}]:-}" ] && to_configure+=( "${repo_name}" )
  done <<< "${source_repos}"

  if [ "${#to_configure[@]}" -gt 0 ]; then
    for repo_name in "${to_configure[@]}"; do
      check_collision "${repo_name}"
      configure_one "${repo_name}"
    done
  fi
}

main
